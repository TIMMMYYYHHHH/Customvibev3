# GEMINI_API_KEY: Required for Gemini AI API calls.
# Set this to your own Gemini API key, or have your hosting platform inject it at runtime.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
# Set this to your deployed domain, or have your hosting platform inject it at runtime.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
